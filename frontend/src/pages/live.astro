								<!-- Step 5 -->
								<div class="flex gap-3 items-start bg-slate-900/30 border border-white/[0.03] p-3 rounded-xl">
									<span class="bg-emerald-500/10 text-emerald-400 font-mono font-bold text-xs w-6 h-6 rounded-full flex items-center justify-center border border-emerald-500/20 flex-shrink-0">5</span>
									<div>
