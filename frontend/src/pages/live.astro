								<span class="w-1.5 h-4 bg-emerald-500 rounded"></span>
								Live SMTP Email Ingestion Flow
							</h3>
							
							<div class="flex flex-col gap-5 mt-2">
								<!-- Step 1 -->
								<div class="flex gap-3 items-start bg-slate-900/30 border border-white/[0.03] p-3 rounded-xl">
									<span class="bg-emerald-500/10 text-emerald-400 font-mono font-bold text-xs w-6 h-6 rounded-full flex items-center justify-center border border-emerald-500/20 flex-shrink-0">1</span>
									<div>
										<h4 class="text-white font-semibold text-sm">Sender Dispatches Email</h4>
										<p class="text-gray-400 text-xs mt-1">A real user sends an email to <code class="text-gray-300 font-semibold">user@yourdomain.com</code> from external providers like Gmail, Yahoo, or Outlook.</p>
									</div>
								</div>
								
								<!-- Step 2 -->
								<div class="flex gap-3 items-start bg-slate-900/30 border border-white/[0.03] p-3 rounded-xl">
									<span class="bg-emerald-500/10 text-emerald-400 font-mono font-bold text-xs w-6 h-6 rounded-full flex items-center justify-center border border-emerald-500/20 flex-shrink-0">2</span>
									<div>
										<h4 class="text-white font-semibold text-sm">DNS Lookup & Routing</h4>
