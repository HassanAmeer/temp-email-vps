---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>TempEmail — Live VPS Console</title>
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="live-console-theme bg-[#0B0F19] text-gray-100 min-h-screen relative overflow-x-hidden">
		<!-- Glow Background -->
		<div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-full h-[400px] bg-radial from-[rgba(16,185,129,0.08)] via-[rgba(5,150,105,0.02)] to-transparent pointer-events-none z-0 rounded-full"></div>
		
		<main class="max-w-[1300px] w-full mx-auto p-8 relative z-10 flex flex-col gap-6 min-h-screen">
			<!-- Top Navbar -->
			<header class="flex justify-between items-center pb-4 border-b border-white/[0.06] flex-wrap gap-4">
				<div class="flex items-center gap-4">
					<a href="/" class="text-gray-400 hover:text-white transition-colors" title="Back to Home">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
							<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
						</svg>
					</a>
					<div class="flex items-center gap-2 font-bold text-xl tracking-tight">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-emerald-400">
							<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
						</svg>
						<span>TempEmail <span class="bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent">Live</span></span>
					</div>
					<span class="text-[10px] font-bold px-2.5 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 uppercase tracking-wider">Live Console</span>
				</div>
				<div class="flex gap-4 items-center flex-wrap">
					<div class="bg-slate-900/50 border border-white/[0.06] px-4 py-2 rounded-full flex items-center gap-2.5 text-xs text-gray-400 backdrop-blur-md">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
						</span>
						<span>SMTP: <strong class="text-emerald-400">Port 25</strong></span>
					</div>
					<div class="bg-slate-900/50 border border-white/[0.06] px-4 py-2 rounded-full flex items-center gap-2.5 text-xs text-gray-400 backdrop-blur-md">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
						</span>
						<span>API: <strong class="text-emerald-400">Port 80 / 8081</strong></span>
					</div>
					<div class="bg-slate-900/50 border border-white/[0.06] px-4 py-2 rounded-full flex items-center gap-2.5 text-xs text-gray-400 backdrop-blur-md">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-gray-500">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
						</svg>
						<span><strong id="emailCount" class="text-white">0</strong> Emails</span>
					</div>
				</div>
			</header>

			<!-- Navigation Tabs -->
			<nav class="flex gap-3 bg-white/[0.02] p-1.5 rounded-xl border border-white/[0.06] w-fit flex-wrap">
				<button class="tab-btn flex items-center gap-2 text-gray-400 px-5 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-all hover:text-white active-tab" data-tab="inbox-tab">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.008 1.24l.885 1.77a2.25 2.25 0 002.007 1.24h1.98a2.25 2.25 0 002.007-1.24l.885-1.77a2.25 2.25 0 012.007-1.24h3.86m-18 0h18m-18 0V9A2.25 2.25 0 014.5 6.75h15A2.25 2.25 0 0121.75 9v4.5m-18 0V18a2.25 2.25 0 002.25 2.25h13.5A2.25 2.25 0 0021 18v-4.5m-15 0V9a1.5 1.5 0 00-1.5-1.5H5.25A1.5 1.5 0 003.75 9v4.5m16.5 0V9a1.5 1.5 0 00-1.5-1.5h-1.5A1.5 1.5 0 0015.75 9v4.5" />
					</svg>
					<span>Live Inbox</span>
				</button>
				<button class="tab-btn flex items-center gap-2 text-gray-400 px-5 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-all hover:text-white" data-tab="json-tab">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
					</svg>
					<span>Selected Email JSON</span>
				</button>
				<button class="tab-btn flex items-center gap-2 text-gray-400 px-5 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-all hover:text-white" data-tab="syslog-tab">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
					</svg>
					<span>Receiving Email Log</span>
				</button>
				<button class="tab-btn flex items-center gap-2 text-gray-400 px-5 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-all hover:text-white" data-tab="send-tab">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
					</svg>
					<span>Send Email</span>
				</button>
			</nav>

			<!-- Content Panes -->
			<div class="flex-grow min-h-[500px] flex">
				
				<!-- TAB 1: INBOX DASHBOARD -->
				<section class="tab-pane active" id="inbox-tab">
					<div class="grid grid-cols-1 md:grid-cols-[320px_1fr] gap-6 w-full min-h-[550px]">
						<!-- Sidebar List -->
						<div class="bg-slate-900/40 border border-white/[0.05] rounded-2xl flex flex-col backdrop-blur-md overflow-hidden">
							<div class="p-5 border-b border-white/[0.06] flex justify-between items-center flex-wrap gap-2">
								<div class="flex items-center gap-3">
									<input type="checkbox" id="selectAllCheckbox" class="cursor-pointer" title="Select All">
									<h3 class="font-bold text-base">Live Messages</h3>
								</div>
								<div class="flex items-center gap-2.5">
									<!-- Delete Selected Button -->
									<button id="deleteSelectedBtn" class="bg-red-500/10 hover:bg-red-500/20 text-red-400 p-1.5 rounded-lg border border-red-500/20 cursor-pointer hidden transition-colors" title="Delete Selected">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
											<path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
										</svg>
									</button>
									<button id="refreshBtn" class="bg-transparent border-none cursor-pointer transition-transform hover:rotate-45" title="Refresh Now">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-gray-400 hover:text-white">
											<path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
										</svg>
									</button>
								</div>
							</div>
							<div class="flex-grow overflow-y-auto max-h-[480px]" id="emailListContainer">
								<div class="flex flex-col items-center justify-center py-16 px-8 text-gray-500 gap-2">
									<span>Waiting for live emails...</span>
								</div>
							</div>
						</div>
						
						<!-- Reader Pane -->
						<div class="bg-slate-900/40 border border-white/[0.05] rounded-2xl flex flex-col backdrop-blur-md overflow-hidden min-h-[550px]" id="emailReaderContainer">
							<div class="flex flex-col items-center justify-center flex-grow text-gray-500 gap-3 p-16 text-center">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-16 h-16 text-gray-600 animate-pulse">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9s2.015-9 4.5-9m0 18c-4.97 0-9-4.03-9-9s4.03-9 9-9m0 18c4.97 0 9-4.03 9-9s-4.03-9-9-9" />
								</svg>
								<h3 class="font-semibold text-lg text-gray-400">Waiting for Emails</h3>
								<p class="text-sm max-w-xs leading-relaxed">Send an email from Gmail/Yahoo/Outlook to your domain and it will appear here instantly.</p>
							</div>
						</div>
					</div>
				</section>

				<!-- TAB 2: SELECTED EMAIL JSON -->
				<section class="tab-pane hidden w-full" id="json-tab">
					<div class="bg-[#0B0E14] border border-white/[0.05] rounded-2xl flex flex-col overflow-hidden shadow-2xl flex-grow">
						<div class="bg-[#111622] px-5 py-3 flex justify-between items-center text-xs font-mono text-gray-400 border-b border-white/[0.06]">
							<span>selected_email.json</span>
							<button class="bg-transparent border border-white/[0.06] text-gray-400 px-3 py-1 rounded cursor-pointer transition-colors hover:bg-white/[0.05] hover:text-white" id="copyJsonBtn">Copy JSON</button>
						</div>
						<pre class="p-5 overflow-auto font-mono text-xs text-[#E2E8F0] leading-relaxed flex-grow max-h-[480px]"><code id="rawJsonCode">// Select an email from the Inbox tab to view raw JSON data</code></pre>
					</div>
				</section>

				<!-- TAB 3: RECEIVING EMAIL LOG -->
				<section class="tab-pane hidden w-full" id="syslog-tab">
					<div class="bg-[#0B0E14] border border-white/[0.05] rounded-2xl flex flex-col overflow-hidden shadow-2xl flex-grow">
						<div class="bg-[#111622] px-5 py-3 flex justify-between items-center text-xs font-mono text-gray-400 border-b border-white/[0.06]">
							<span>receiving_traffic.log</span>
							<button class="bg-transparent border border-white/[0.06] text-gray-400 px-3 py-1 rounded cursor-pointer transition-colors hover:bg-white/[0.05] hover:text-white" id="copyLogsBtn">Copy Logs</button>
						</div>
						<pre class="p-5 overflow-auto font-mono text-xs text-emerald-400 bg-[#05070A] leading-relaxed flex-grow max-h-[480px]"><code id="systemLogsCode">[System] Listening for incoming public connections...</code></pre>
					</div>
				</section>

				<!-- TAB 4: SEND EMAIL -->
				<section class="tab-pane hidden w-full" id="send-tab">
					<div class="bg-[#0B0E14] border border-white/[0.05] rounded-2xl flex flex-col overflow-hidden shadow-2xl flex-grow p-8 max-w-[800px] mx-auto w-full">
						<div class="mb-6">
							<h2 class="text-2xl font-bold text-white mb-2">Compose Email</h2>
							<p class="text-sm text-gray-400">Send an email directly from your generated email addresses to anyone.</p>
						</div>
						<form id="sendEmailForm" class="flex flex-col gap-5 flex-grow">
							<div class="flex flex-col gap-1.5">
								<label for="sendFrom" class="text-xs font-semibold text-gray-300 uppercase tracking-wider">From</label>
								<input type="email" id="sendFrom" required placeholder="e.g. yourname@llamerada.online" class="bg-[#111622] border border-white/[0.06] rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-emerald-500/50 transition-colors">
							</div>
							<div class="flex flex-col gap-1.5">
								<label for="sendTo" class="text-xs font-semibold text-gray-300 uppercase tracking-wider">To</label>
								<input type="email" id="sendTo" required placeholder="e.g. friend@gmail.com" class="bg-[#111622] border border-white/[0.06] rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-emerald-500/50 transition-colors">
							</div>
							<div class="flex flex-col gap-1.5">
								<label for="sendSubject" class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Subject</label>
								<input type="text" id="sendSubject" required placeholder="Email subject" class="bg-[#111622] border border-white/[0.06] rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-emerald-500/50 transition-colors">
							</div>
							<div class="flex flex-col gap-1.5">
								<label for="sendAttachments" class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Attachments</label>
								<input type="file" id="sendAttachments" multiple class="bg-[#111622] border border-white/[0.06] rounded-lg px-4 py-3 text-sm text-gray-400 focus:outline-none focus:border-emerald-500/50 transition-colors">
							</div>
							<div class="flex flex-col gap-1.5 flex-grow">
								<label for="sendMessage" class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Message (HTML or Plain Text)</label>
								<textarea id="sendMessage" required placeholder="Type your message here..." class="bg-[#111622] border border-white/[0.06] rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-emerald-500/50 transition-colors min-h-[200px] flex-grow resize-none"></textarea>
							</div>
							
							<div id="sendAlert" class="hidden rounded-lg px-4 py-3 text-sm font-semibold mt-2"></div>

							<div class="flex justify-end mt-2">
								<button type="submit" id="submitSendBtn" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 px-8 rounded-lg shadow-lg hover:shadow-emerald-500/20 transition-all cursor-pointer flex items-center gap-2">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
									</svg>
									<span>Send Email</span>
								</button>
							</div>
						</form>
						
						<!-- Send Email Realtime Logs Box -->
						<div class="mt-6 border border-white/[0.06] rounded-xl overflow-hidden bg-[#0A0F1D] flex flex-col">
							<div class="bg-[#111622] px-4 py-2 border-b border-white/[0.06] flex items-center justify-between">
								<h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider flex items-center gap-2">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-emerald-400">
										<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
									</svg>
									Real-time Send Logs
								</h3>
							</div>
							<pre class="p-4 overflow-auto font-mono text-[11px] text-emerald-400/80 leading-relaxed max-h-[150px] min-h-[100px] flex-col-reverse flex" id="sendingLogContainer"><code id="sendingLogsCode">Waiting for send actions...</code></pre>
						</div>
					</div>
				</section>

			</div>

			<!-- Footer -->
			<footer class="flex flex-col items-center gap-4 pt-6 border-t border-white/[0.06] mt-auto">
				<p class="text-xs text-gray-500 font-mono">Live Console Port: 25. Emails: backend/storage/live/</p>
			</footer>
		</main>

			
			<!-- Help / Instruction Floating Button -->
			<button id="helpBtn" class="fixed bottom-6 right-6 bg-emerald-500 hover:bg-emerald-600 text-white w-12 h-12 rounded-full flex items-center justify-center shadow-lg hover:shadow-emerald-500/20 transition-all hover:scale-110 cursor-pointer z-40 border border-emerald-400/20 animate-pulse" style={{ animationDuration: '2s' }} title="Instructions & Guide">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
					<path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
				</svg>
			</button>

			<!-- Instruction Modal -->
			<div id="helpModal" class="modal fixed top-0 left-0 w-screen h-screen bg-black/80 backdrop-blur-[5px] z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
				<div class="bg-[#0F1626] border border-white/[0.06] w-full max-w-[650px] rounded-2xl overflow-hidden shadow-2xl flex flex-col max-h-[85vh]">
					<!-- Header -->
					<div class="p-5 border-b border-white/[0.06] flex justify-between items-center bg-[#131B2E]">
						<div class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-emerald-400">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
							</svg>
							<h2 class="text-lg font-bold text-white">System Guide & Documentation</h2>
						</div>
						<button class="bg-transparent border-none text-gray-400 text-2xl cursor-pointer hover:text-white transition-colors" id="closeHelpModalBtn">&times;</button>
					</div>

					<!-- Tabs selector -->
					<div class="flex border-b border-white/[0.06] bg-[#0A0F1D]">
						<button class="help-tab-btn flex-1 py-3 text-sm font-semibold text-emerald-400 border-b-2 border-emerald-500 bg-white/[0.02]" data-help-tab="how-it-works-help">Live Email Flow</button>
						<button class="help-tab-btn flex-1 py-3 text-sm font-semibold text-gray-400 border-b-2 border-transparent hover:text-white transition-all" data-help-tab="vps-setup-help">VPS & Domain Setup</button>
					</div>

					<!-- Content area (scrollable) -->
					<div class="p-6 overflow-y-auto flex-grow text-gray-300 text-sm leading-relaxed flex flex-col gap-4">
						<!-- Content 1: Live Email Flow -->
						<div id="how-it-works-help" class="help-tab-pane flex flex-col gap-4">
