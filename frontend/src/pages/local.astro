---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>TempEmail — Local Console</title>
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="local-console-theme bg-[#0B0F19] text-gray-100 min-h-screen relative overflow-x-hidden">
		<!-- Glow Background -->
		<div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-full h-[400px] bg-radial from-[rgba(56,189,248,0.08)] via-[rgba(129,140,248,0.02)] to-transparent pointer-events-none z-0 rounded-full"></div>
		
		<main class="max-w-[1300px] w-full mx-auto p-8 relative z-10 flex flex-col gap-6 min-h-screen">
			<!-- Top Navbar -->
			<header class="flex justify-between items-center pb-4 border-b border-white/[0.06] flex-wrap gap-4">
				<div class="flex items-center gap-4">
					<a href="/" class="text-gray-400 hover:text-white transition-colors" title="Back to Home">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
							<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
						</svg>
					</a>
					<div class="flex items-center gap-2 font-bold text-xl tracking-tight">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-sky-400">
							<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
						</svg>
						<span>TempEmail <span class="bg-gradient-to-r from-sky-400 to-indigo-400 bg-clip-text text-transparent">Local</span></span>
					</div>
					<span class="text-[10px] font-bold px-2.5 py-0.5 rounded-full bg-sky-500/10 text-sky-400 border border-sky-500/20 uppercase tracking-wider">Local Console</span>
				</div>
				<div class="flex gap-4 items-center flex-wrap">
					<div class="bg-slate-900/50 border border-white/[0.06] px-4 py-2 rounded-full flex items-center gap-2.5 text-xs text-gray-400 backdrop-blur-md">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-sky-500"></span>
						</span>
						<span>SMTP: <strong class="text-emerald-400">Port 2525</strong></span>
					</div>
					<div class="bg-slate-900/50 border border-white/[0.06] px-4 py-2 rounded-full flex items-center gap-2.5 text-xs text-gray-400 backdrop-blur-md">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-sky-500"></span>
						</span>
						<span>API: <strong class="text-emerald-400">Port 8081</strong></span>
					</div>
					<div class="bg-slate-900/50 border border-white/[0.06] px-4 py-2 rounded-full flex items-center gap-2.5 text-xs text-gray-400 backdrop-blur-md">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-gray-500">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
						</svg>
						<span><strong id="emailCount" class="text-white">0</strong> Emails</span>
					</div>
				</div>
			</header>

			<!-- Navigation Tabs -->
			<nav class="flex gap-3 bg-white/[0.02] p-1.5 rounded-xl border border-white/[0.06] w-fit flex-wrap">
				<button class="tab-btn flex items-center gap-2 text-gray-400 px-5 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-all hover:text-white active-tab" data-tab="inbox-tab">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.008 1.24l.885 1.77a2.25 2.25 0 002.007 1.24h1.98a2.25 2.25 0 002.007-1.24l.885-1.77a2.25 2.25 0 012.007-1.24h3.86m-18 0h18m-18 0V9A2.25 2.25 0 014.5 6.75h15A2.25 2.25 0 0121.75 9v4.5m-18 0V18a2.25 2.25 0 002.25 2.25h13.5A2.25 2.25 0 0021 18v-4.5m-15 0V9a1.5 1.5 0 00-1.5-1.5H5.25A1.5 1.5 0 003.75 9v4.5m16.5 0V9a1.5 1.5 0 00-1.5-1.5h-1.5A1.5 1.5 0 0015.75 9v4.5" />
					</svg>
					<span>Inbox</span>
				</button>
				<button class="tab-btn flex items-center gap-2 text-gray-400 px-5 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-all hover:text-white" data-tab="json-tab">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
					</svg>
					<span>Selected Email JSON</span>
				</button>
				<button class="tab-btn flex items-center gap-2 text-gray-400 px-5 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-all hover:text-white" data-tab="syslog-tab">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
					</svg>
					<span>Receiving Email Log</span>
				</button>
				<button class="tab-btn flex items-center gap-2 text-gray-400 px-5 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-all hover:text-white" data-tab="sending-tab">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
					</svg>
					<span>Sending Email Log</span>
				</button>
				<button class="tab-btn flex items-center gap-2 text-gray-400 px-5 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-all hover:text-white" data-tab="send-tab">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
					</svg>
					<span>Send Email</span>
				</button>
			</nav>

			<!-- Content Panes -->
			<div class="flex-grow min-h-[500px] flex">
				
				<!-- TAB 1: INBOX DASHBOARD -->
				<section class="tab-pane active" id="inbox-tab">
					<div class="grid grid-cols-1 md:grid-cols-[320px_1fr] gap-6 w-full min-h-[550px]">
						<!-- Sidebar List -->
						<div class="bg-slate-900/40 border border-white/[0.05] rounded-2xl flex flex-col backdrop-blur-md overflow-hidden">
							<div class="p-5 border-b border-white/[0.06] flex justify-between items-center flex-wrap gap-2">
								<div class="flex items-center gap-3">
									<input type="checkbox" id="selectAllCheckbox" class="cursor-pointer" title="Select All">
									<h3 class="font-bold text-base">Inbox Messages</h3>
								</div>
								<div class="flex items-center gap-2.5">
									<!-- Delete Selected Button -->
									<button id="deleteSelectedBtn" class="bg-red-500/10 hover:bg-red-500/20 text-red-400 p-1.5 rounded-lg border border-red-500/20 cursor-pointer hidden transition-colors" title="Delete Selected">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
											<path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
										</svg>
									</button>
									<button id="refreshBtn" class="bg-transparent border-none cursor-pointer transition-transform hover:rotate-45" title="Refresh Now">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-gray-400 hover:text-white">
											<path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
										</svg>
									</button>
								</div>
							</div>
							<div class="flex-grow overflow-y-auto max-h-[480px]" id="emailListContainer">
								<div class="flex flex-col items-center justify-center py-16 px-8 text-gray-500 gap-2">
									<span>Loading emails...</span>
								</div>
							</div>
						</div>
						
						<!-- Reader Pane -->
						<div class="bg-slate-900/40 border border-white/[0.05] rounded-2xl flex flex-col backdrop-blur-md overflow-hidden min-h-[550px]" id="emailReaderContainer">
							<div class="flex flex-col items-center justify-center flex-grow text-gray-500 gap-3 p-16 text-center">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-16 h-16 text-gray-600 animate-pulse">
									<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 9v.906a2.25 2.25 0 01-1.183 1.981l-6.478 3.488a2.25 2.25 0 01-2.178 0L5.431 11.887A2.25 2.25 0 014.25 9.906V9M21.75 9a2.25 2.25 0 00-2.25-2.25h-15A2.25 2.25 0 002.25 9m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
								</svg>
								<h3 class="font-semibold text-lg text-gray-400">No Email Selected</h3>
								<p class="text-sm max-w-xs leading-relaxed">Select an email from the left sidebar to read its contents, headers, and attachments.</p>
							</div>
						</div>
					</div>
				</section>

				<!-- TAB 2: SELECTED EMAIL JSON -->
				<section class="tab-pane hidden w-full" id="json-tab">
					<div class="bg-[#0B0E14] border border-white/[0.05] rounded-2xl flex flex-col overflow-hidden shadow-2xl flex-grow">
						<div class="bg-[#111622] px-5 py-3 flex justify-between items-center text-xs font-mono text-gray-400 border-b border-white/[0.06]">
							<span>selected_email.json</span>
							<button class="bg-transparent border border-white/[0.06] text-gray-400 px-3 py-1 rounded cursor-pointer transition-colors hover:bg-white/[0.05] hover:text-white" id="copyJsonBtn">Copy JSON</button>
						</div>
						<pre class="p-5 overflow-auto font-mono text-xs text-[#E2E8F0] leading-relaxed flex-grow max-h-[480px]"><code id="rawJsonCode">// Select an email from the Inbox tab to view raw JSON data</code></pre>
					</div>
				</section>

				<!-- TAB 3: RECEIVING EMAIL LOG -->
				<section class="tab-pane hidden w-full" id="syslog-tab">
					<div class="bg-[#0B0E14] border border-white/[0.05] rounded-2xl flex flex-col overflow-hidden shadow-2xl flex-grow">
						<div class="bg-[#111622] px-5 py-3 flex justify-between items-center text-xs font-mono text-gray-400 border-b border-white/[0.06]">
							<span>receiving_traffic.log</span>
							<button class="bg-transparent border border-white/[0.06] text-gray-400 px-3 py-1 rounded cursor-pointer transition-colors hover:bg-white/[0.05] hover:text-white" id="copyLogsBtn">Copy Logs</button>
						</div>
						<pre class="p-5 overflow-auto font-mono text-xs text-sky-400 bg-[#05070A] leading-relaxed flex-grow max-h-[480px]"><code id="systemLogsCode">[System] Initializing connection and waiting for logs...</code></pre>
					</div>
				</section>

				<!-- TAB 4: SENDING EMAIL LOG -->
				<section class="tab-pane hidden w-full" id="sending-tab">
					<div class="bg-[#0B0E14] border border-white/[0.05] rounded-2xl flex flex-col overflow-hidden shadow-2xl flex-grow">
						<div class="bg-[#111622] px-5 py-3 flex justify-between items-center text-xs font-mono text-gray-400 border-b border-white/[0.06]">
							<span>sending_traffic.log</span>
							<button class="bg-transparent border border-white/[0.06] text-gray-400 px-3 py-1 rounded cursor-pointer transition-colors hover:bg-white/[0.05] hover:text-white" id="copySendingLogsBtn">Copy Logs</button>
						</div>
						<pre class="p-5 overflow-auto font-mono text-xs text-sky-400 bg-[#05070A] leading-relaxed flex-grow max-h-[480px]"><code id="sendingLogsCode">[System] Ready to capture Nodemailer SMTP outbound logs...</code></pre>
					</div>
				</section>

				<!-- TAB 4: SEND EMAIL -->
				<section class="tab-pane hidden w-full" id="send-tab">
					<div class="bg-white border border-slate-200 rounded-2xl flex flex-col overflow-hidden shadow-sm flex-grow p-8 max-w-[800px] mx-auto w-full">
						<div class="mb-6">
							<h2 class="text-2xl font-bold text-slate-800 mb-2">Compose Email</h2>
							<p class="text-sm text-slate-500">Send an email directly from your generated email addresses to anyone.</p>
						</div>
						<form id="sendEmailForm" class="flex flex-col gap-5 flex-grow">
							<div class="flex flex-col gap-1.5">
								<label for="sendFrom" class="text-xs font-semibold text-slate-600 uppercase tracking-wider">From</label>
								<input type="email" id="sendFrom" required placeholder="e.g. yourname@llamerada.online" class="bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-800 focus:outline-none focus:border-indigo-500/50 transition-colors">
							</div>
							<div class="flex flex-col gap-1.5">
								<label for="sendTo" class="text-xs font-semibold text-slate-600 uppercase tracking-wider">To</label>
								<input type="email" id="sendTo" required placeholder="e.g. friend@gmail.com" class="bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-800 focus:outline-none focus:border-indigo-500/50 transition-colors">
							</div>
							<div class="flex flex-col gap-1.5">
								<label for="sendSubject" class="text-xs font-semibold text-slate-600 uppercase tracking-wider">Subject</label>
								<input type="text" id="sendSubject" required placeholder="Email subject" class="bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-800 focus:outline-none focus:border-indigo-500/50 transition-colors">
							</div>
							<div class="flex flex-col gap-1.5">
								<label for="sendAttachments" class="text-xs font-semibold text-slate-600 uppercase tracking-wider">Attachments</label>
								<input type="file" id="sendAttachments" multiple class="text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer">
							</div>
							<div class="flex flex-col gap-1.5 flex-grow">
								<label for="sendMessage" class="text-xs font-semibold text-slate-600 uppercase tracking-wider">Message (HTML or Plain Text)</label>
								<textarea id="sendMessage" required placeholder="Type your message here..." class="bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-800 focus:outline-none focus:border-indigo-500/50 transition-colors min-h-[200px] flex-grow resize-none"></textarea>
							</div>
							
							<div id="sendAlert" class="hidden rounded-lg px-4 py-3 text-sm font-semibold mt-2"></div>

							<div class="flex justify-end mt-2">
								<button type="submit" id="submitSendBtn" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-8 rounded-lg shadow-sm hover:shadow transition-all cursor-pointer flex items-center gap-2">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
									</svg>
									<span>Send Email</span>
								</button>
							</div>
						</form>
						
						<!-- Send Email Realtime Logs Box -->
						<div class="mt-6 border border-slate-200 rounded-xl overflow-hidden bg-slate-50 flex flex-col">
							<div class="bg-slate-100 px-4 py-2 border-b border-slate-200 flex items-center justify-between">
								<h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider flex items-center gap-2">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-indigo-500">
										<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
									</svg>
									Real-time Send Logs
								</h3>
							</div>
							<pre class="p-4 overflow-auto font-mono text-[11px] text-indigo-600 leading-relaxed max-h-[150px] min-h-[100px] flex-col-reverse flex" id="sendingLogContainer"><code id="sendingLogsCode">Waiting for send actions...</code></pre>
						</div>
					</div>
				</section>

			</div>

			<!-- Footer -->
			<footer class="flex flex-col items-center gap-4 pt-6 border-t border-white/[0.06] mt-auto">
				<div class="flex gap-4">
					<button class="bg-sky-500/10 border border-sky-500/25 text-sky-400 hover:bg-sky-500/20 px-6 py-2.5 rounded-lg font-semibold cursor-pointer transition-all flex items-center gap-2 shadow-lg shadow-sky-500/5 disabled:opacity-50" id="nodemailerTestBtn">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.43l-1.003.828c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.02-.397-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.43l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.991l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28z" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
						</svg>
						<span>Send Test Email (Nodemailer)</span>
					</button>
				</div>
				<p class="text-xs text-gray-500 font-mono">Local Console Port: 2525. Emails: backend/storage/local/</p>
			</footer>

			<!-- Help / Instruction Floating Button -->
			<button id="helpBtn" class="fixed bottom-6 right-6 bg-sky-500 hover:bg-sky-600 text-white w-12 h-12 rounded-full flex items-center justify-center shadow-lg hover:shadow-sky-500/20 transition-all hover:scale-110 cursor-pointer z-40 border border-sky-400/20 animate-pulse" style={{ animationDuration: '2s' }} title="Instructions & Guide">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
					<path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
				</svg>
			</button>

			<!-- Instruction Modal -->
			<div id="helpModal" class="modal fixed top-0 left-0 w-screen h-screen bg-black/80 backdrop-blur-[5px] z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
				<div class="bg-[#0F1626] border border-white/[0.06] w-full max-w-[650px] rounded-2xl overflow-hidden shadow-2xl flex flex-col max-h-[85vh]">
					<!-- Header -->
					<div class="p-5 border-b border-white/[0.06] flex justify-between items-center bg-[#131B2E]">
						<div class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-sky-400">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
							</svg>
							<h2 class="text-lg font-bold text-white">Local Console Guide</h2>
						</div>
						<button class="bg-transparent border-none text-gray-400 text-2xl cursor-pointer hover:text-white transition-colors" id="closeHelpModalBtn">&times;</button>
					</div>

					<!-- Tabs selector -->
					<div class="flex border-b border-white/[0.06] bg-[#0A0F1D]">
						<button class="help-tab-btn flex-1 py-3 text-sm font-semibold text-sky-400 border-b-2 border-sky-500 bg-white/[0.02]" data-help-tab="how-it-works-help">Local Flow</button>
						<button class="help-tab-btn flex-1 py-3 text-sm font-semibold text-gray-400 border-b-2 border-transparent hover:text-white transition-all" data-help-tab="local-smtp-testing-help">Local SMTP Testing</button>
					</div>

					<!-- Content area (scrollable) -->
					<div class="p-6 overflow-y-auto flex-grow text-gray-300 text-sm leading-relaxed flex flex-col gap-4">
						<!-- Content 1: How it works -->
						<div id="how-it-works-help" class="help-tab-pane flex flex-col gap-4">
							<h3 class="text-white font-bold text-base flex items-center gap-2">
								<span class="w-1.5 h-4 bg-sky-500 rounded"></span>
								Local SMTP & Mail Trap Workflow
							</h3>
							<ul class="list-disc pl-5 flex flex-col gap-2.5 text-gray-400">
								<li><strong>SMTP Connection:</strong> A local SMTP server runs on port <code class="bg-black/40 px-1.5 py-0.5 rounded text-sky-400 font-mono">2525</code>, listening for incoming email traffic.</li>
								<li><strong>Parsing Service:</strong> When an email is sent to port 2525, the server captures it and routes the raw stream to <code class="text-white font-semibold">mailparser</code>.</li>
								<li><strong>Metadata Extraction:</strong> HTML bodies, plain text, headers, and attachments are processed and extracted automatically.</li>
								<li><strong>JSON File Storage:</strong> The parsed results are stored as individual <code class="bg-black/40 px-1.5 py-0.5 rounded text-sky-400 font-mono">.json</code> transaction records inside the folder <code class="text-gray-200">backend/storage/local/</code>.</li>
								<li><strong>Real-time Dashboard:</strong> This dashboard polls the local server API on port <code class="bg-black/40 px-1.5 py-0.5 rounded text-sky-400 font-mono">8081</code> every 3 seconds to fetch new items.</li>
								<li><strong>Audio Notification:</strong> When a new email arrives, a bell notification plays (<code class="text-gray-200">bell.wav</code>).</li>
							</ul>

							<!-- Explanation callout -->
							<div class="bg-slate-900/50 border border-white/[0.04] p-4 rounded-xl mt-3 flex flex-col gap-3">
								<div class="flex items-center gap-2 text-sky-400 font-semibold text-xs uppercase tracking-wider">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4.5 h-4.5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
									</svg>
									<span>Why are these Protocols & Ports used?</span>
								</div>
								<div class="flex flex-col gap-2.5 text-xs text-gray-400 leading-relaxed">
									<p>💡 <strong class="text-gray-300">Why SMTP Protocol?</strong> SMTP (Simple Mail Transfer Protocol) is the absolute global standard for email transmission. Every email server in the world (Gmail, Yahoo, etc.) communicates using this protocol. There are no alternative protocols for receiving raw inter-server mail deliveries.</p>
									<p>🔌 <strong class="text-gray-300">Why Port 2525 locally instead of Port 25?</strong> Standard SMTP operates on Port 25. However, macOS and Linux restrict port numbers below 1024 to root/administrator accounts only. To allow developers to run, test, and debug this email server locally without root privileges, we use port <code class="bg-black/30 px-1 py-0.5 rounded text-sky-400 font-mono">2525</code>.</p>
									<p>🌐 <strong class="text-gray-300">Why Port 8081?</strong> Port 8081 runs our separate lightweight HTTP server that serves parsed email JSON files via a REST API to this dashboard frontend. This ensures we don't block SMTP socket transactions on port 2525 with web UI requests.</p>
								</div>
							</div>
						</div>

						<!-- Content 2: Local SMTP Testing -->
						<div id="local-smtp-testing-help" class="help-tab-pane hidden flex flex-col gap-4">
							<h3 class="text-white font-bold text-base flex items-center gap-2">
								<span class="w-1.5 h-4 bg-sky-500 rounded"></span>
								SMTP Testing & Sending
							</h3>
							<p>You can send test emails to your local SMTP trap server using standard libraries or CLI scripts:</p>
							<ol class="list-decimal pl-5 flex flex-col gap-3 text-gray-400">
								<li>
									<strong>Using the Send Button:</strong> Click the <code class="text-white">Send Test Email (Nodemailer)</code> button at the bottom of the console page. This triggers an internal script connecting to <code class="text-sky-400 font-mono">127.0.0.1:2525</code> to dispatch a test email.
								</li>
								<li>
									<strong>Using Nodemailer in scripts:</strong>
									<pre class="bg-black/50 p-2.5 rounded font-mono text-xs text-sky-300 mt-1.5 select-all">{"const transporter = nodemailer.createTransport({\n  host: \"127.0.0.1\",\n  port: 2525,\n  secure: false\n});"}</pre>
								</li>
								<li>
									<strong>Using telnet or netcat:</strong> Send raw SMTP transactions directly from your terminal:
									<pre class="bg-black/50 p-2.5 rounded font-mono text-xs text-sky-300 mt-1.5 select-all">nc localhost 2525</pre>
								</li>
							</ol>
						</div>
					</div>
				</div>
			</div>
		</main>

		<!-- Client side Script for Real-Time Updating -->
		<script is:inline>
			const API_BASE = "http://localhost:8081";
			const API_URL = window.location.port === "4321" ? API_BASE : `${window.location.protocol}//${window.location.host}`;

			let emailsData = [];
			let selectedEmailId = null;
			let knownEmailIds = null;

			function playBellSound() {
				const audio = new Audio("/bell.wav");
				audio.play().catch(err => {
					console.warn("Audio playback failed (interaction required):", err);
				});
			}

			// Tab Switching Logic
			const tabButtons = document.querySelectorAll('.tab-btn');
			const tabPanes = document.querySelectorAll('.tab-pane');

			tabButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					tabButtons.forEach(b => {
						b.classList.remove('text-white', 'bg-white/[0.05]', 'active-tab');
						b.classList.add('text-gray-400');
					});
					tabPanes.forEach(p => p.classList.add('hidden'));

					btn.classList.add('text-white', 'bg-white/[0.05]', 'active-tab');
					btn.classList.remove('text-gray-400');
					
					const targetPane = document.getElementById(btn.getAttribute('data-tab'));
					if (targetPane) targetPane.classList.remove('hidden');
				});
			});

			const activeTabBtn = document.querySelector('.tab-btn.active-tab');
			if (activeTabBtn) {
				activeTabBtn.classList.add('text-white', 'bg-white/[0.05]');
				activeTabBtn.classList.remove('text-gray-400');
			}

			// Visibility of Delete Selected Button
			function updateDeleteSelectedBtnVisibility() {
				const checked = document.querySelectorAll('.email-checkbox:checked');
				const btn = document.getElementById('deleteSelectedBtn');
				if (btn) {
					if (checked.length > 0) {
						btn.classList.remove('hidden');
					} else {
						btn.classList.add('hidden');
					}
				}
			}

			// Fetch Emails from API
			async function fetchEmails() {
				try {
					const res = await fetch(`${API_URL}/api/emails/local`);
					if (!res.ok) throw new Error("API Connection Failed");
					const data = await res.json();
					
					// Play sound if a new email is received
					if (knownEmailIds !== null) {
						let hasNewEmail = false;
						data.forEach(email => {
							if (!knownEmailIds.has(email.id)) {
								hasNewEmail = true;
							}
						});
						if (hasNewEmail) {
							playBellSound();
						}
					}
					knownEmailIds = new Set(data.map(email => email.id));

					emailsData = data;
					document.getElementById('emailCount').textContent = data.length;
					renderEmailList(data);
					
					if (selectedEmailId) {
						const currentSelected = data.find(e => e.id === selectedEmailId);
						if (currentSelected) {
							renderEmailReader(currentSelected);
							document.getElementById('rawJsonCode').textContent = JSON.stringify(currentSelected, null, 2);
						}
					}
				} catch (err) {
					console.error("Error fetching emails:", err);
				}
			}

			// Fetch logs
			async function fetchLogs() {
				try {
					// 1. Fetch Receiving Logs
					const resRec = await fetch(`${API_URL}/api/logs/local/receiving`);
					if (resRec.ok) {
						const logsRec = await resRec.json();
						const logsCode = document.getElementById('systemLogsCode');
						if (logsCode) {
							logsCode.textContent = logsRec.join('\n');
						}
					}
					
					// 2. Fetch Sending Logs
					const resSend = await fetch(`${API_URL}/api/logs/local/sending`);
					if (resSend.ok) {
						const logsSend = await resSend.json();
						const sendingCode = document.getElementById('sendingLogsCode');
						if (sendingCode) {
							sendingCode.textContent = logsSend.join('\n');
						}
					}
				} catch (err) {
					console.error("Error fetching logs:", err);
				}
			}

			// Render Sidebar List
			function renderEmailList(emails) {
				const container = document.getElementById('emailListContainer');
				if (!container) return;

				if (emails.length === 0) {
					container.innerHTML = `
						<div class="flex flex-col items-center justify-center py-16 px-8 text-gray-500 gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-gray-600">
								<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.008 1.24l.885 1.77a2.25 2.25 0 002.007 1.24h1.98a2.25 2.25 0 002.007-1.24l.885-1.77a2.25 2.25 0 012.007-1.24h3.86m-18 0h18m-18 0V9A2.25 2.25 0 014.5 6.75h15A2.25 2.25 0 0121.75 9v4.5m-18 0V18a2.25 2.25 0 002.25 2.25h13.5A2.25 2.25 0 0021 18v-4.5m-15 0V9a1.5 1.5 0 00-1.5-1.5H5.25A1.5 1.5 0 003.75 9v4.5m16.5 0V9a1.5 1.5 0 00-1.5-1.5h-1.5A1.5 1.5 0 0015.75 9v4.5" />
							</svg>
							<p class="text-sm">No local messages received.</p>
						</div>
					`;
					return;
				}

				// Check standard boxes before re-render
				const previouslyCheckedFilenames = new Set(
					Array.from(document.querySelectorAll('.email-checkbox:checked')).map(cb => cb.getAttribute('data-filename'))
				);

				const readEmails = JSON.parse(localStorage.getItem('localReadEmails') || '[]');
				const readEmailSet = new Set(readEmails);

				container.innerHTML = emails.map(email => {
					const dateStr = new Date(email.date).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
					const isSelected = email.id === selectedEmailId ? 'bg-sky-500/5 border-l-2 border-sky-400' : 'border-l-2 border-transparent';
					
					const hasAttachment = email.attachments && email.attachments.length > 0;
					const attachmentSvg = hasAttachment ? `
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 text-gray-500 inline-block align-middle ml-1">
							<path stroke-linecap="round" stroke-linejoin="round" d="M18.375 12.739l-7.693 7.693a4.5 4.5 0 01-6.364-6.364l10.94-10.94A3 3 0 1119.5 7.372L8.552 18.32m.009-.01l-.01.01m5.699-9.941l-7.81 7.81a1.5 1.5 0 002.112 2.13" />
						</svg>
					` : '';

					const isChecked = previouslyCheckedFilenames.has(email.fileName) ? 'checked' : '';

					const isRead = readEmailSet.has(email.id);
					const readBadge = isRead ? `
						<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-white/[0.04] text-gray-500 border border-white/[0.05] uppercase tracking-wider">Read</span>
					` : `
						<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-sky-500/10 text-sky-400 border border-sky-500/20 uppercase tracking-wider animate-pulse">New</span>
					`;
					
					const fontClass = isRead ? 'font-normal text-gray-400' : 'font-bold text-white';
					const subjectFontClass = isRead ? 'font-medium text-gray-300' : 'font-semibold text-white';

					return `
						<div class="p-4 border-b border-white/[0.04] cursor-pointer transition-colors hover:bg-white/[0.01] flex gap-3 items-start ${isSelected}" data-id="${email.id}">
							<input type="checkbox" class="email-checkbox mt-0.5 cursor-pointer" data-filename="${email.fileName}" ${isChecked}>
							<div class="flex-grow flex flex-col gap-1.5 overflow-hidden">
								<div class="flex justify-between items-center">
									<span class="text-xs ${fontClass} overflow-hidden text-ellipsis whitespace-nowrap max-w-[180px]">${escapeHTML(email.from)}</span>
									<div class="flex items-center gap-2">
										${readBadge}
										<span class="text-[10px] text-gray-500 font-mono">${dateStr}</span>
									</div>
								</div>
								<div class="text-xs overflow-hidden text-ellipsis whitespace-nowrap flex items-center justify-between ${subjectFontClass}">
									<span>${escapeHTML(email.subject)}</span>
									${attachmentSvg}
								</div>
								<div class="text-[11px] text-gray-400 line-clamp-2 leading-relaxed">${escapeHTML(email.text.slice(0, 50))}${email.text.length > 50 ? '...' : ''}</div>
							</div>
						</div>
					`;
				}).join('');

				// Event listener on item
				document.querySelectorAll('[data-id]').forEach(item => {
					item.addEventListener('click', (e) => {
						const emailId = item.getAttribute('data-id');
						selectEmail(emailId);
					});

					const checkbox = item.querySelector('.email-checkbox');
					if (checkbox) {
						checkbox.addEventListener('click', (e) => {
							e.stopPropagation(); // Stops clicking checkbox from selecting email
							updateDeleteSelectedBtnVisibility();
						});
					}
				});
				updateDeleteSelectedBtnVisibility();
			}

			function selectEmail(id) {
				selectedEmailId = id;
				const email = emailsData.find(e => e.id === id);
				if (email) {
					// Mark as read in localStorage
					let readEmails = JSON.parse(localStorage.getItem('localReadEmails') || '[]');
					if (!readEmails.includes(id)) {
						readEmails.push(id);
						localStorage.setItem('localReadEmails', JSON.stringify(readEmails));
					}

					renderEmailReader(email);
					document.getElementById('rawJsonCode').textContent = JSON.stringify(email, null, 2);
					fetchEmails();
				}
			}

			// Render Email Detail
			function renderEmailReader(email) {
				const container = document.getElementById('emailReaderContainer');
				if (!container) return;

				const dateStr = new Date(email.date).toLocaleString();
				const hasAttachments = email.attachments && email.attachments.length > 0;

				container.innerHTML = `
					<div class="p-6 border-b border-white/[0.06] flex flex-col gap-3">
						<div class="flex justify-between items-start gap-4">
							<h2 class="text-xl font-bold text-white">${escapeHTML(email.subject)}</h2>
							<button class="bg-red-500/10 border border-red-500/25 hover:bg-red-500/25 text-red-400 px-3.5 py-1.5 rounded-lg text-xs font-semibold cursor-pointer transition-colors" id="deleteMailBtn" data-filename="${email.fileName}">Delete Email</button>
						</div>
						<div class="flex flex-col gap-1 text-xs text-gray-300">
							<div><strong>From:</strong> ${escapeHTML(email.from)}</div>
							<div><strong>To:</strong> ${escapeHTML(email.to)}</div>
							<div class="flex gap-4 text-gray-500 text-[10px] mt-1.5 font-mono">
								<span>Time: ${dateStr}</span>
								<span>Sender IP: ${email.senderIp}</span>
							</div>
						</div>
					</div>
					<div class="flex-grow flex flex-col p-5 gap-3">
						<div class="flex gap-2 border-b border-white/[0.05] pb-2">
							<button class="bg-white/[0.05] text-white px-3 py-1 rounded text-xs font-medium cursor-pointer" id="btnShowHtml">Rich Text (HTML)</button>
							<button class="text-gray-400 px-3 py-1 rounded text-xs font-medium cursor-pointer hover:text-white" id="btnShowText">Plain Text</button>
						</div>
						<div class="flex-grow bg-black/30 rounded-xl border border-white/[0.05] overflow-hidden min-h-[280px] flex">
							<div id="htmlContent" class="w-full flex-grow flex">
								${email.html ? `<iframe srcdoc="${escapeIframe(email.html)}" class="w-full h-full border-none bg-white" sandbox="allow-same-origin" title="Email content"></iframe>` : `<pre class="p-5 whitespace-pre-wrap break-all font-mono text-xs text-gray-200 overflow-y-auto w-full">${escapeHTML(email.text)}</pre>`}
							</div>
							<div id="textContent" class="w-full flex-grow flex hidden">
								<pre class="p-5 whitespace-pre-wrap break-all font-mono text-xs text-gray-200 overflow-y-auto w-full">${escapeHTML(email.text)}</pre>
							</div>
						</div>
					</div>
					${hasAttachments ? `
						<div class="p-5 bg-white/[0.01] border-t border-white/[0.06] flex flex-col gap-3">
							<h4 class="text-xs font-bold uppercase tracking-wider text-gray-400 flex items-center gap-1.5">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M18.375 12.739l-7.693 7.693a4.5 4.5 0 01-6.364-6.364l10.94-10.94A3 3 0 1119.5 7.372L8.552 18.32m.009-.01l-.01.01m5.699-9.941l-7.81 7.81a1.5 1.5 0 002.112 2.13" />
								</svg>
								<span>Attachments (${email.attachments.length})</span>
							</h4>
							<div class="flex flex-wrap gap-2">
								${email.attachments.map(att => {
									const isImage = att.contentType && att.contentType.startsWith('image/');
									return `
									<a href="${att.url}" target="_blank" class="bg-slate-900 border border-white/[0.06] rounded-lg p-3 flex items-center gap-3 max-w-[280px] hover:bg-slate-800 transition-colors cursor-pointer group">
										${isImage 
											? `<img src="${att.url}" class="w-10 h-10 object-cover rounded bg-white/5" alt="thumbnail" />` 
											: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-blue-400"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25M9 16.5v.75m3-3v3m3-6v6m-10.125-3H18.75m-16.5 4.5h16.5" /></svg>`
										}
										<div class="flex flex-col overflow-hidden">
											<span class="text-xs font-semibold text-gray-200 overflow-hidden text-ellipsis whitespace-nowrap group-hover:text-blue-400">${escapeHTML(att.filename)}</span>
											<span class="text-[10px] text-gray-500 font-mono mt-0.5">${formatBytes(att.size)} &bull; Download</span>
										</div>
									</a>
								`}).join('')}
							</div>
						</div>
					` : ''}
				`;

				const btnShowHtml = document.getElementById('btnShowHtml');
				const btnShowText = document.getElementById('btnShowText');
				const htmlContent = document.getElementById('htmlContent');
				const textContent = document.getElementById('textContent');

				if (btnShowHtml && btnShowText && htmlContent && textContent) {
					btnShowHtml.addEventListener('click', () => {
						btnShowHtml.classList.add('bg-white/[0.05]', 'text-white');
						btnShowHtml.classList.remove('text-gray-400');
						btnShowText.classList.remove('bg-white/[0.05]', 'text-white');
						btnShowText.classList.add('text-gray-400');
						htmlContent.classList.remove('hidden');
						textContent.classList.add('hidden');
					});

					btnShowText.addEventListener('click', () => {
						btnShowText.classList.add('bg-white/[0.05]', 'text-white');
						btnShowText.classList.remove('text-gray-400');
						btnShowHtml.classList.remove('bg-white/[0.05]', 'text-white');
						btnShowHtml.classList.add('text-gray-400');
						textContent.classList.remove('hidden');
						htmlContent.classList.add('hidden');
					});
				}

				const deleteMailBtn = document.getElementById('deleteMailBtn');
				if (deleteMailBtn) {
					// Single email delete WITHOUT confirmation dialog
					deleteMailBtn.addEventListener('click', async () => {
						const filename = deleteMailBtn.getAttribute('data-filename');
						try {
							const res = await fetch(`${API_URL}/api/emails/delete/local/${filename}`, { method: 'POST' });
							if (res.ok) {
								selectedEmailId = null;
								fetchEmails();
								container.innerHTML = `
									<div class="flex flex-col items-center justify-center flex-grow text-gray-500 gap-3 p-16 text-center">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-16 h-16 text-gray-600">
											<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
										</svg>
										<h3 class="font-semibold text-lg text-gray-400">Email Deleted</h3>
										<p class="text-sm max-w-xs">Select another email from the sidebar.</p>
									</div>
								`;
								document.getElementById('rawJsonCode').textContent = "// Email deleted";
							}
						} catch (err) {
							console.error(err);
						}
					});
				}
			}

			// Select All / Unselect All Logic
			const selectAllCheckbox = document.getElementById('selectAllCheckbox');
			if (selectAllCheckbox) {
				selectAllCheckbox.addEventListener('change', () => {
					const checkboxes = document.querySelectorAll('.email-checkbox');
					checkboxes.forEach(cb => cb.checked = selectAllCheckbox.checked);
					updateDeleteSelectedBtnVisibility();
				});
			}

			// Send Email Form Logic
			const sendEmailForm = document.getElementById('sendEmailForm');
			if (sendEmailForm) {
				sendEmailForm.addEventListener('submit', async (e) => {
					e.preventDefault();
					const btn = document.getElementById('submitSendBtn');
					const alertBox = document.getElementById('sendAlert');
					
					const from = document.getElementById('sendFrom').value;
					const to = document.getElementById('sendTo').value;
					const subject = document.getElementById('sendSubject').value;
					const message = document.getElementById('sendMessage').value;
					const fileInput = document.getElementById('sendAttachments');

					if (!to) {
						alertBox.textContent = 'Recipient "To" address is required';
						alertBox.classList.remove('hidden');
						return;
					}

					// Process attachments
					let attachments = [];
					if (fileInput.files.length > 0) {
						const files = Array.from(fileInput.files);
						const filePromises = files.map(file => {
							return new Promise((resolve, reject) => {
								const reader = new FileReader();
								reader.onload = (e) => {
									const base64 = e.target.result.split(',')[1];
									resolve({
										filename: file.name,
										content: base64
									});
								};
								reader.onerror = reject;
								reader.readAsDataURL(file);
							});
						});
						
						btn.innerHTML = `<span class="animate-spin inline-block w-4 h-4 border-2 border-white/30 border-t-white rounded-full"></span> Processing Files...`;
						attachments = await Promise.all(filePromises);
					}

					btn.innerHTML = `<span class="animate-spin inline-block w-4 h-4 border-2 border-white/30 border-t-white rounded-full"></span> Sending...`;
					btn.classList.add('opacity-75', 'cursor-not-allowed');
					alertBox.classList.add('hidden');

					try {
						const res = await fetch(`${API_URL}/api/send-email/local`, {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({
								from,
								to,
								subject,
								text: message,
								html: message.replace(/\n/g, '<br>'),
								attachments
							})
						});

						const data = await res.json();
						
						if (data.success) {
							alertBox.className = 'rounded-lg px-4 py-3 text-sm font-semibold mt-2 bg-indigo-500/10 text-indigo-700 border border-indigo-500/20';
							alertBox.textContent = '✅ Email sent successfully!';
							alertBox.classList.remove('hidden');
							document.getElementById('sendSubject').value = '';
							document.getElementById('sendMessage').value = '';
						} else {
							throw new Error(data.error || 'Failed to send email');
						}
					} catch (err) {
						alertBox.className = 'rounded-lg px-4 py-3 text-sm font-semibold mt-2 bg-red-500/10 text-red-600 border border-red-500/20';
						alertBox.textContent = '❌ Error: ' + err.message;
						alertBox.classList.remove('hidden');
					} finally {
						btn.disabled = false;
						btn.innerHTML = `
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
							</svg>
							<span>Send Email</span>
						`;
						btn.classList.remove('opacity-75', 'cursor-not-allowed');
					}
				});
			}

			// Delete Selected Button Logic (WITHOUT confirmation)
			const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');
			if (deleteSelectedBtn) {
				deleteSelectedBtn.addEventListener('click', async () => {
					const checked = document.querySelectorAll('.email-checkbox:checked');
					const filenames = Array.from(checked).map(cb => cb.getAttribute('data-filename'));
					if (filenames.length === 0) return;

					deleteSelectedBtn.disabled = true;

					try {
						// Delete multiple emails simultaneously
						await Promise.all(filenames.map(filename =>
							fetch(`${API_URL}/api/emails/delete/local/${filename}`, { method: 'POST' })
						));

						if (selectAllCheckbox) selectAllCheckbox.checked = false;
						selectedEmailId = null;

						const reader = document.getElementById('emailReaderContainer');
						if (reader) {
							reader.innerHTML = `
								<div class="flex flex-col items-center justify-center flex-grow text-gray-500 gap-3 p-16 text-center">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-16 h-16 text-gray-600">
										<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
									</svg>
									<h3 class="font-semibold text-lg text-gray-400">Emails Deleted</h3>
									<p class="text-sm max-w-xs">Selected messages deleted successfully.</p>
								</div>
							`;
						}
						document.getElementById('rawJsonCode').textContent = "// Emails deleted";
						fetchEmails();
					} catch (err) {
						console.error("Error deleting selected:", err);
					} finally {
						deleteSelectedBtn.disabled = false;
					}
				});
			}

			// Nodemailer local test trigger
			const nodemailerTestBtn = document.getElementById('nodemailerTestBtn');
			if (nodemailerTestBtn) {
				nodemailerTestBtn.addEventListener('click', async () => {
					nodemailerTestBtn.disabled = true;
					const orig = nodemailerTestBtn.innerHTML;
					nodemailerTestBtn.innerHTML = "⏳ Sending...";

					try {
						const res = await fetch(`${API_URL}/api/test-send/local`, { method: "POST" });
						const data = await res.json();
						if (data.success) {
							fetchEmails();
							fetchLogs();
						}
					} catch (err) {
						console.error(err);
					} finally {
						nodemailerTestBtn.disabled = false;
						nodemailerTestBtn.innerHTML = orig;
					}
				});
			}

			// Copy JSON
			const copyJsonBtn = document.getElementById('copyJsonBtn');
			if (copyJsonBtn) {
				copyJsonBtn.addEventListener('click', () => {
					const codeText = document.getElementById('rawJsonCode').textContent;
					navigator.clipboard.writeText(codeText);
					copyJsonBtn.textContent = "Copied!";
					setTimeout(() => copyJsonBtn.textContent = "Copy JSON", 2000);
				});
			}

			// Copy Logs
			const copyLogsBtn = document.getElementById('copyLogsBtn');
			if (copyLogsBtn) {
				copyLogsBtn.addEventListener('click', () => {
					const codeText = document.getElementById('systemLogsCode').textContent;
					navigator.clipboard.writeText(codeText);
					copyLogsBtn.textContent = "Copied!";
					setTimeout(() => copyLogsBtn.textContent = "Copy Logs", 2000);
				});
			}

			// Copy Sending Logs
			const copySendingLogsBtn = document.getElementById('copySendingLogsBtn');
			if (copySendingLogsBtn) {
				copySendingLogsBtn.addEventListener('click', () => {
					const codeText = document.getElementById('sendingLogsCode').textContent;
					navigator.clipboard.writeText(codeText);
					copySendingLogsBtn.textContent = "Copied!";
					setTimeout(() => copySendingLogsBtn.textContent = "Copy Logs", 2000);
				});
			}

			// Refresh button
			const refreshBtn = document.getElementById('refreshBtn');
			if (refreshBtn) {
				refreshBtn.addEventListener('click', () => {
					fetchEmails();
					fetchLogs();
				});
			}

			function escapeHTML(str) {
				if (!str) return "";
				return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
			}

			function escapeIframe(html) {
				if (!html) return "";
				return html.replace(/"/g, "&quot;");
			}

			function formatBytes(bytes) {
				if (bytes === 0) return '0 Bytes';
				const k = 1024;
				const sizes = ['Bytes', 'KB', 'MB'];
				const i = Math.floor(Math.log(bytes) / Math.log(k));
				return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
			}

			// Help Modal Dialog Logic
			const helpBtn = document.getElementById('helpBtn');
			const helpModal = document.getElementById('helpModal');
			const closeHelpModalBtn = document.getElementById('closeHelpModalBtn');

			if (helpBtn && helpModal && closeHelpModalBtn) {
				helpBtn.addEventListener('click', () => {
					helpModal.classList.remove('opacity-0', 'pointer-events-none');
				});
				closeHelpModalBtn.addEventListener('click', () => {
					helpModal.classList.add('opacity-0', 'pointer-events-none');
				});
				helpModal.addEventListener('click', (e) => {
					if (e.target === helpModal) {
						helpModal.classList.add('opacity-0', 'pointer-events-none');
					}
				});
			}

			// Help Modal Tabs Switch
			const helpTabButtons = document.querySelectorAll('.help-tab-btn');
			const helpTabPanes = document.querySelectorAll('.help-tab-pane');

			helpTabButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					helpTabButtons.forEach(b => {
						b.classList.remove('text-sky-400', 'border-sky-500', 'bg-white/[0.02]');
						b.classList.add('text-gray-400', 'border-transparent');
					});
					helpTabPanes.forEach(p => p.classList.add('hidden'));

					btn.classList.add('text-sky-400', 'border-sky-500', 'bg-white/[0.02]');
					btn.classList.remove('text-gray-400', 'border-transparent');

					const targetPane = document.getElementById(btn.getAttribute('data-help-tab'));
					if (targetPane) targetPane.classList.remove('hidden');
				});
			});

			// Initial & Polling
			fetchEmails();
			fetchLogs();
			setInterval(() => {
				fetchEmails();
				fetchLogs();
			}, 3000);
		</script>
	</body>
</html>
