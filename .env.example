# ==========================================
# 🌍 ENVIRONMENT CONFIGURATION
# ==========================================
# Set live=true for Production VPS
# Set live=false for Local Development Machine
live=true

# ==========================================
# 📊 CURRENT PORT USAGE (Kaunsi Port Kahan Use Hoti Hai?)
# ==========================================
#
# [ 🔴 LIVE ENVIRONMENT (live=true) ]
# - Web Dashboard (UI)        : Port 80
# - Receive Email (Inbound)   : Port 25   (Standard port for receiving emails from Gmail/Yahoo)
# - Send Email (Outbound)     : Port 25   (Used by our code to send emails out to the internet)
# - External App Relay (Auth) : Port 2525 (Used by on-smtp server for 3rd party apps to connect)
#
# [ 🔵 LOCAL ENVIRONMENT (live=false) ]
# - Web Dashboard (UI)        : Port 8081 (Taake live port 80 se takrao/conflict na ho)
# - Receive Email (Inbound)   : Port 2525 (Local machines aam taur par port 25 block karti hain)
# - Send Email (Outbound)     : Port 25   (Local testing ke liye code port 25 par send karne ki koshish karta hai)
# - External App Relay (Auth) : Port 2525 (Used by on-smtp server)
